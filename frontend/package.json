{
  "name": "termbook-frontend",
  "private": true,
  "version": "1.0.0",
  "description": "Termbook frontend — React + xterm.js client. See ../README.md for the full project.",
  "author": "Jianling Zhong",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jianlingzhong/termbook.git",
    "directory": "frontend"
  },
  "homepage": "https://github.com/jianlingzhong/termbook",
  "keywords": [
    "terminal",
    "web-terminal",
    "notebook",
    "react",
    "xterm",
    "xtermjs",
    "vite",
    "frontend",
    "ssh",
    "shell",
    "self-hosted"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:visual": "playwright test --config playwright.visual.config.js",
    "test:visual:ci": "TERMBOOK_CI=1 playwright test --config playwright.visual.config.js",
    "test:motion": "playwright test --config playwright.visual.config.js tests/visual/motion.spec.mjs",
    "test:regression": "playwright test --config playwright.visual.config.js tests/visual/regression.spec.mjs",
    "test:e2e": "playwright test --config playwright.e2e.config.js",
    "test:e2e:update": "playwright test --config playwright.e2e.config.js --update-snapshots=all",
    "test:e2e:headed": "playwright test --config playwright.e2e.config.js --headed",
    "test:all": "npm run test:visual && npm run test:e2e"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^5.5.0",
    "lucide-react": "^0.563.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^16.5.0",
    "vite": "^7.3.1"
  }
}
